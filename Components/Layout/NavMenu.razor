@* Top navigation. Mobile menu and the account dropdown are pure client-side state via Alpine. *@

<header data-nav-header
        class="sticky top-0 z-40 border-b border-line/80 bg-ink/80 backdrop-blur-xl relative"
        x-data="{ open: false, search: false }">
    @* Top-loading progress bar. Driven by app.js on Blazor navigation. *@
    <div id="nav-progress"
         class="pointer-events-none absolute inset-x-0 bottom-0 z-50 h-0.5 origin-left bg-brand"
         style="transform:scaleX(0);opacity:0"></div>
    <nav class="flex w-full items-center gap-4 px-4 py-3 sm:px-6 lg:px-10">
        <a href="/" class="flex shrink-0 items-center gap-2 text-lg font-extrabold tracking-tight">
            <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand text-white">M</span>
            <span>Movies<span class="text-brand">Mafia</span></span>
        </a>

        <div class="hidden items-center gap-1 md:flex">
            <NavItem Href="movies" Label="Movies" />
            <NavItem Href="series" Label="Series" />
            @* Points at the search page in its browse/discover mode (empty query =
               popular titles + filters). The navbar search bar covers quick lookups. *@
            <NavItem Href="search" Label="Discover" />
            <NavItem Href="about" Label="About" />
            <AuthorizeView Roles="Admin">
                <NavItem Href="admin/users" Label="Admin" />
            </AuthorizeView>
        </div>

        @* Desktop quick-search. GET form → /search?q=... (no antiforgery needed for a safe
           GET). data-enhance routes it through Blazor enhanced navigation, so submitting
           morphs the page (progress bar, no full reload) like the rest of the app. The
           Search page seeds the reactive SearchBox from ?q=. *@
        <form method="get" action="/search" role="search" data-enhance
              class="ml-auto hidden max-w-xs flex-1 items-center md:flex lg:max-w-sm">
            <div class="relative w-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                </svg>
                <input type="search" name="q" autocomplete="off"
                       placeholder="Search movies & series…"
                       aria-label="Search movies and series"
                       class="input h-10 pl-9 pr-3 py-0" />
            </div>
            <button type="submit" class="btn-primary ml-2 h-10 shrink-0 px-4">Search</button>
        </form>

        <div class="ml-3 hidden items-center gap-2 md:flex">
            <AuthorizeView>
                <Authorized>
                    <a href="account/profile" class="btn-ghost">@context.User.Identity?.Name</a>
                    <form method="post" action="/account/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="btn-subtle">Sign out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="account/login" class="btn-subtle">Sign in</a>
                    <a href="account/signup" class="btn-primary">Get started</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        @* Mobile actions: search toggle + hamburger. The search bar (below) is hidden
           until the icon is tapped, so it doesn't permanently eat vertical space. *@
        <div class="ml-auto flex items-center gap-2 md:hidden">
            <button type="button"
                    class="grid h-11 w-11 place-items-center rounded-lg border border-line bg-surface-2/60 text-content transition hover:bg-surface-2"
                    aria-label="Toggle search" x-bind:aria-expanded="search"
                    x-on:click="search = !search; if (search) $nextTick(() => $refs.mobileSearchInput?.focus())">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                </svg>
            </button>
            <button type="button"
                    class="grid h-11 w-11 place-items-center rounded-lg border border-line bg-surface-2/60 text-content transition hover:bg-surface-2"
                    aria-label="Toggle menu" x-bind:aria-expanded="open"
                    x-on:click="open = !open">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </nav>

    @* Mobile quick-search. Hidden until the search icon in the nav is tapped, so it
       doesn't permanently take vertical space. Separate from the hamburger dropdown.
       Server-rendered display:none so an enhanced-nav morph keeps it collapsed. *@
    <div class="border-t border-line/60 px-4 py-2.5 md:hidden"
         x-show="search" x-cloak x-transition style="display:none">
        <form method="get" action="/search" role="search" data-enhance class="flex items-center gap-2">
            <div class="relative flex-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                </svg>
                <input type="search" name="q" autocomplete="off"
                       x-ref="mobileSearchInput"
                       placeholder="Search movies & series…"
                       aria-label="Search movies and series"
                       class="input pl-9" />
            </div>
            <button type="submit" class="btn-primary shrink-0 px-4" aria-label="Search">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                </svg>
            </button>
        </form>
    </div>

    @* Absolute so the open menu overlays the hero instead of pushing it down.
       style="display:none" is server-rendered so an enhanced-navigation morph keeps
       the menu closed: Idiomorph would otherwise strip the runtime display:none Alpine
       adds (incoming server HTML lacks it), leaving the menu visible on the new page. *@
    <div class="absolute inset-x-0 top-full z-40 border-b border-line/80 bg-ink/95 backdrop-blur-xl md:hidden"
         x-show="open" x-cloak x-transition style="display:none">
        <div class="space-y-1 px-4 py-3">
            <a href="movies" class="block rounded-lg px-3 py-2 text-sm text-content hover:bg-surface-2">Movies</a>
            <a href="series" class="block rounded-lg px-3 py-2 text-sm text-content hover:bg-surface-2">Series</a>
            <a href="search" class="block rounded-lg px-3 py-2 text-sm text-content hover:bg-surface-2">Discover</a>
            <a href="about" class="block rounded-lg px-3 py-2 text-sm text-content hover:bg-surface-2">About</a>
            <AuthorizeView Roles="Admin">
                <a href="admin/users" class="block rounded-lg px-3 py-2 text-sm text-content hover:bg-surface-2">Admin</a>
            </AuthorizeView>
            <div class="mt-2 flex gap-2 border-t border-line/80 pt-3">
                <AuthorizeView>
                    <Authorized>
                        <a href="account/profile" class="btn-ghost flex-1">Profile</a>
                        <form method="post" action="/account/logout" class="flex-1">
                            <AntiforgeryToken />
                            <button type="submit" class="btn-subtle w-full">Sign out</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="account/login" class="btn-ghost flex-1">Sign in</a>
                        <a href="account/signup" class="btn-primary flex-1">Get started</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</header>
