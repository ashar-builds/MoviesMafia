@page "/movies"
@attribute [StreamRendering]
@using MoviesMafia.Services.Tmdb
@using MoviesMafia.Services.Tmdb.Dtos
@inject ITmdbClient Tmdb

<PageTitle>Movies — MoviesMafia</PageTitle>

<HeroCarousel Slides="_hero" Loading="_heroLoading" />

<div class="w-full px-4 pb-16 sm:px-6 lg:px-10">

    <TrendingSection Kind="movies" />

    <MediaRow Title="Popular movies" Subtitle="Loved by everyone" Loading="_popular is null">
        @foreach (var m in _popular ?? Empty())
        {
            @Card(m)
        }
    </MediaRow>

    <MediaRow Title="Now playing in theaters" Subtitle="Catch the latest releases" Loading="_nowPlaying is null">
        @foreach (var m in _nowPlaying ?? Empty())
        {
            @Card(m)
        }
    </MediaRow>

    <MediaRow Title="Top rated movies" Subtitle="The all-time greats according to TMDB" Loading="_topRated is null">
        @foreach (var m in _topRated ?? Empty())
        {
            @Card(m)
        }
    </MediaRow>

    <MediaRow Title="Upcoming movies" Subtitle="Mark your calendar" Loading="_upcoming is null">
        @foreach (var m in _upcoming ?? Empty())
        {
            @Card(m)
        }
    </MediaRow>
</div>

@code {
    private const int RowSize = HomeMappers.RowSize;

    private List<HeroSlide> _hero = new();
    private bool _heroLoading = true;
    private List<MovieResult>? _popular;
    private List<MovieResult>? _nowPlaying;
    private List<MovieResult>? _topRated;
    private List<MovieResult>? _upcoming;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadHeroAsync(),
            HomeMappers.LoadRow(async () => (await Tmdb.GetPopularMoviesAsync()).Results.Take(RowSize).ToList(), r => _popular = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetNowPlayingMoviesAsync()).Results.Take(RowSize).ToList(), r => _nowPlaying = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetTopRatedMoviesAsync()).Results.Take(RowSize).ToList(), r => _topRated = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetUpcomingMoviesAsync()).Results.Take(RowSize).ToList(), r => _upcoming = r));
    }

    private async Task LoadHeroAsync()
    {
        try
        {
            _hero = HomeMappers.ToHeroSlides((await Tmdb.GetTrendingMoviesAsync("day")).Results, Tmdb, "Trending movie");
        }
        catch { /* hero carousel renders its own empty state */ }
        finally { _heroLoading = false; }
    }

    private static IEnumerable<MovieResult> Empty() => [];

    private RenderFragment Card(MovieResult m) =>
        @<div class="w-44 shrink-0 snap-start sm:w-52">
            <MediaCard Title="@(m.Title ?? "Untitled")"
                       PosterUrl="@Tmdb.ImageUrl(m.PosterPath)"
                       Overview="@m.Overview"
                       Year="@HomeMappers.Year(m.ReleaseDate)"
                       Score="m.VoteAverage"
                       TrailerUrl="@($"/trailer/movie/{m.Id}")"
                       WatchUrl="@($"/watch/movie/{m.Id}")"
                       DetailsUrl="@($"/details/movie/{m.Id}")" />
        </div>;
}
