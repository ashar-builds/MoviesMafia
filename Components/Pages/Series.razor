@page "/series"
@attribute [StreamRendering]
@using MoviesMafia.Services.Tmdb
@using MoviesMafia.Services.Tmdb.Dtos
@inject ITmdbClient Tmdb

<PageTitle>Series — MoviesMafia</PageTitle>

<HeroCarousel Slides="_hero" Loading="_heroLoading" />

<div class="w-full px-4 pb-16 sm:px-6 lg:px-10">

    <TrendingSection Kind="series" />

    <MediaRow Title="Popular series" Subtitle="The shows everyone's binging" Loading="_popular is null">
        @foreach (var s in _popular ?? Empty())
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="On the air" Subtitle="Series with new episodes airing now" Loading="_onTheAir is null">
        @foreach (var s in _onTheAir ?? Empty())
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="Airing today" Subtitle="Fresh episodes in the next 24 hours" Loading="_airingToday is null">
        @foreach (var s in _airingToday ?? Empty())
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="Top rated series" Subtitle="Binge-worthy classics" Loading="_topRated is null">
        @foreach (var s in _topRated ?? Empty())
        {
            @Card(s)
        }
    </MediaRow>
</div>

@code {
    private const int RowSize = HomeMappers.RowSize;

    private List<HeroSlide> _hero = new();
    private bool _heroLoading = true;
    private List<SeriesResult>? _popular;
    private List<SeriesResult>? _onTheAir;
    private List<SeriesResult>? _airingToday;
    private List<SeriesResult>? _topRated;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadHeroAsync(),
            HomeMappers.LoadRow(async () => (await Tmdb.GetPopularSeriesAsync()).Results.Take(RowSize).ToList(), r => _popular = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetOnTheAirSeriesAsync()).Results.Take(RowSize).ToList(), r => _onTheAir = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetAiringTodaySeriesAsync()).Results.Take(RowSize).ToList(), r => _airingToday = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetTopRatedSeriesAsync()).Results.Take(RowSize).ToList(), r => _topRated = r));
    }

    private async Task LoadHeroAsync()
    {
        try
        {
            _hero = HomeMappers.ToHeroSlides((await Tmdb.GetTrendingSeriesAsync("day")).Results, Tmdb, "Trending series");
        }
        catch { /* hero carousel renders its own empty state */ }
        finally { _heroLoading = false; }
    }

    private static IEnumerable<SeriesResult> Empty() => [];

    private RenderFragment Card(SeriesResult s) =>
        @<div class="w-44 shrink-0 snap-start sm:w-52">
            <MediaCard Title="@(s.Name ?? "Untitled")"
                       PosterUrl="@Tmdb.ImageUrl(s.PosterPath)"
                       Overview="@s.Overview"
                       Year="@HomeMappers.Year(s.FirstAirDate)"
                       Score="s.VoteAverage"
                       TrailerUrl="@($"/trailer/series/{s.Id}")"
                       WatchUrl="@($"/watch/series/{s.Id}")"
                       DetailsUrl="@($"/details/series/{s.Id}")" />
        </div>;
}
