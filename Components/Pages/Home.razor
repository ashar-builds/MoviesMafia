@page "/"
@attribute [StreamRendering]
@using MoviesMafia.Services.Tmdb
@using MoviesMafia.Services.Tmdb.Dtos
@inject ITmdbClient Tmdb

<PageTitle>MoviesMafia — Stream the classics</PageTitle>

@* Hero is full-bleed (no padding around it). *@
<HeroCarousel Slides="_hero" Loading="_heroLoading" />

@* Everything else uses the immersive full-width canvas with breathing room. *@
<div class="w-full px-4 pb-16 sm:px-6 lg:px-10">

    @* Server-driven filters via ReactiveBlazor. *@
    <TrendingSection />
    <PopularSection />

    <MediaRow Title="Now playing in theaters" Subtitle="Catch the latest releases" MoreUrl="/movies" Loading="_nowPlaying is null">
        @foreach (var m in _nowPlaying ?? Empty<MovieResult>())
        {
            @MovieCard(m)
        }
    </MediaRow>

    <MediaRow Title="Top rated movies" Subtitle="The all-time greats according to TMDB" MoreUrl="/movies" Loading="_topRatedMovies is null">
        @foreach (var m in _topRatedMovies ?? Empty<MovieResult>())
        {
            @MovieCard(m)
        }
    </MediaRow>

    <MediaRow Title="Upcoming movies" Subtitle="Mark your calendar" Loading="_upcoming is null">
        @foreach (var m in _upcoming ?? Empty<MovieResult>())
        {
            @MovieCard(m)
        }
    </MediaRow>

    <MediaRow Title="On the air" Subtitle="Series with new episodes airing now" MoreUrl="/series" Loading="_onTheAir is null">
        @foreach (var s in _onTheAir ?? Empty<SeriesResult>())
        {
            @SeriesCard(s)
        }
    </MediaRow>

    <MediaRow Title="Top rated series" Subtitle="Binge-worthy classics" Loading="_topRatedSeries is null">
        @foreach (var s in _topRatedSeries ?? Empty<SeriesResult>())
        {
            @SeriesCard(s)
        }
    </MediaRow>

</div>

@code {
    private const int RowSize = HomeMappers.RowSize;

    // null = still loading (row shows skeletons); non-null = loaded (possibly empty on failure).
    private List<HeroSlide> _hero = new();
    private bool _heroLoading = true;
    private List<MovieResult>? _nowPlaying;
    private List<MovieResult>? _topRatedMovies;
    private List<MovieResult>? _upcoming;
    private List<SeriesResult>? _onTheAir;
    private List<SeriesResult>? _topRatedSeries;

    protected override async Task OnInitializedAsync()
    {
        // Each row streams in independently: one slow or failing TMDB endpoint
        // no longer blanks the whole page (StreamRendering flushes as each completes).
        await Task.WhenAll(
            LoadHeroAsync(),
            HomeMappers.LoadRow(async () => (await Tmdb.GetNowPlayingMoviesAsync()).Results.Take(RowSize).ToList(), r => _nowPlaying = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetTopRatedMoviesAsync()).Results.Take(RowSize).ToList(), r => _topRatedMovies = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetUpcomingMoviesAsync()).Results.Take(RowSize).ToList(), r => _upcoming = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetOnTheAirSeriesAsync()).Results.Take(RowSize).ToList(), r => _onTheAir = r),
            HomeMappers.LoadRow(async () => (await Tmdb.GetTopRatedSeriesAsync()).Results.Take(RowSize).ToList(), r => _topRatedSeries = r));
    }

    private async Task LoadHeroAsync()
    {
        try
        {
            _hero = HomeMappers.ToHeroSlides((await Tmdb.GetTrendingMoviesAsync("day")).Results, Tmdb);
        }
        catch { /* hero carousel renders its own empty state */ }
        finally { _heroLoading = false; }
    }

    private static IEnumerable<T> Empty<T>() => [];

    private static string? Year(string? date) => HomeMappers.Year(date);

    private RenderFragment MovieCard(MovieResult m) =>
        @<div class="w-44 shrink-0 snap-start sm:w-52">
            <MediaCard Title="@(m.Title ?? "Untitled")"
                       PosterUrl="@Tmdb.ImageUrl(m.PosterPath)"
                       Overview="@m.Overview"
                       Year="@Year(m.ReleaseDate)"
                       Score="m.VoteAverage"
                       TrailerUrl="@($"/trailer/movie/{m.Id}")"
                       WatchUrl="@($"/watch/movie/{m.Id}")"
                       DetailsUrl="@($"/details/movie/{m.Id}")" />
        </div>;

    private RenderFragment SeriesCard(SeriesResult s) =>
        @<div class="w-44 shrink-0 snap-start sm:w-52">
            <MediaCard Title="@(s.Name ?? "Untitled")"
                       PosterUrl="@Tmdb.ImageUrl(s.PosterPath)"
                       Overview="@s.Overview"
                       Year="@Year(s.FirstAirDate)"
                       Score="s.VoteAverage"
                       TrailerUrl="@($"/trailer/series/{s.Id}")"
                       WatchUrl="@($"/watch/series/{s.Id}")"
                       DetailsUrl="@($"/details/series/{s.Id}")" />
        </div>;
}
