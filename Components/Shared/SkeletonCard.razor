@* Poster-shaped loading placeholder that mirrors MediaCard's dimensions so rows
   don't shift when real content streams in. *@

<div class="w-44 shrink-0 snap-start sm:w-52" aria-hidden="true">
    <div class="card overflow-hidden">
        <div class="skeleton aspect-[2/3] w-full rounded-none"></div>
        <div class="space-y-2 p-3">
            <div class="skeleton h-4 w-3/4"></div>
            <div class="skeleton h-3 w-1/3"></div>
        </div>
    </div>
</div>
